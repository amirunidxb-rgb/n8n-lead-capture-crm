      "id": "e4299582-2f37-45b1-be30-c330fd0deb02",
      "name": "Store Lead in CRM"
    },
    {
      "parameters": {
        "jsCode": "const budget = Number($json.budget || 0);\n\nlet score = 0;\n\n// Budget scoring\nif (budget >= 5000) {\n  score += 50;\n} else if (budget >= 2000) {\n  score += 30;\n} else {\n  score += 10;\n}\n\n// Company bonus\nif ($json.company) {\n  score += 20;\n}\n\n// Service scoring\nif ($json.service?.toLowerCase().includes('website')) {\n  score += 10;\n}\n\n// Final lead status\nlet priority = 'low';\n\nif (score >= 70) {\n  priority = 'high';\n} else if (score >= 40) {\n  priority = 'medium';\n}\n\nreturn [\n  {\n    json: {\n      ...$json,\n      lead_score: score,\n      priority\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
        0
      ],
      "id": "0afbed0f-f23c-45de-aa22-d3c436e581ed",
      "name": "Calculate Lead Score"
    },
    {
      "parameters": {
        "chatId": "={{$env.TELEGRAM_CHAT_ID}}",
        "text": "=\ud83d\ude80 New Lead Captured\n\n\ud83d\udc64 Name: {{$json.full_name}}\n\n\ud83c\udfe2 Company: {{$json.company}}\n\n\ud83d\udcb0 Budget: ${{$json.budget}}\n\n\ud83d\udcc8 Score: {{$json.lead_score}}\n\n\ud83d\udd25 Priority: {{$json.priority}}\n\n\ud83d\udce7 Email: {{$json.email}}\n\n\ud83d\udee0 Service: {{$json.service}}",
        "additionalFields": {
